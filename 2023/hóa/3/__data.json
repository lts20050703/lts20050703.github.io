}," 0,54 và 5,16g",{"answer":330,"id":22}," 8,1 và 5,24g\u003Cbr\u003E",27,{"question":333,"answers":334,"id":341,"right":13}," Cho 2,7 gam kim loại Al tác dụng với dung dịch NaOH dư, sau phản ứng hoàn toàn thu được V lít khí H\u003Csub\u003E2\u003C\u002Fsub\u003E (đktc). Giá trị của V là\u003Cbr\u003E",[335,336,337,339],{"answer":312,"id":13},{"answer":316,"id":16},{"answer":338,"id":19}," 1,12.",{"answer":340,"id":22}," 2,24.\u003Cbr\u003E",28,{"question":343,"answers":344,"id":353,"right":19}," Nung 6,0 gam hỗn hợp Al và Fe trong không khí, thu được 8,4 gam hỗn hợp X chỉ chứa các oxit. Hòa tan hoàn toàn X cần vừa đủ V ml dung dịch HCl 1M. Giá trị V là\u003Cbr\u003E",[345,347,349,351],{"answer":346,"id":13}," 200.",{"answer":348,"id":16}," 150.",{"answer":350,"id":19}," 300.",{"answer":352,"id":22}," 400.\u003Cbr\u003E",29,{"question":355,"answers":356,"id":364,"right":19}," Hòa tan hoàn toàn Fe\u003Csub\u003E3\u003C\u002Fsub\u003EO\u003Csub\u003E4\u003C\u002Fsub\u003E trong dung dịch H\u003Csub\u003E2\u003C\u002Fsub\u003ESO\u003Csub\u003E4\u003C\u002Fsub\u003E (loãng, dư), thu được dung dịch X. Chất nào sau đây không phản ứng với dung dịch X?\u003Cbr\u003E",[357,359,361,362],{"answer":358,"id":13}," KMnO\u003Csub\u003E4\u003C\u002Fsub\u003E.",{"answer":360,"id":16}," KNO\u003Csub\u003E3\u003C\u002Fsub\u003E.",{"answer":249,"id":19},{"answer":363,"id":22}," Cu.\u003Cbr\u003E",30,{"question":366,"answers":367,"id":376,"right":16}," Phát biểu nào sau đây là đúng?\u003Cbr\u003E",[368,370,372,374],{"answer":369,"id":13}," Kim loại Na tác dụng với dung dịch AlCl\u003Csub\u003E3\u003C\u002Fsub\u003E, thu được kim loại Al.\u003Cbr\u003E",{"answer":371,"id":16}," Hỗn hợp gồm Na\u003Csub\u003E2\u003C\u002Fsub\u003EO và Al\u003Csub\u003E2\u003C\u002Fsub\u003EO\u003Csub\u003E3\u003C\u002Fsub\u003E (tỉ lệ mol 1 : 1) tan được hoàn toàn trong nước dư.\u003Cbr\u003E",{"answer":373,"id":19}," Thạch cao sống dùng để nặn tượng, bó bột khi gãy xương.\u003Cbr\u003E",{"answer":375,"id":22}," Điện phân MgCl\u003Csub\u003E2\u003C\u002Fsub\u003E nóng chảy, thu được khí Cl\u003Csub\u003E2\u003C\u002Fsub\u003E ở catot.\u003Cbr\u003E",31,{"question":378,"answers":379,"id":388,"right":19}," Hòa tan hoàn toàn m gam Al vào dung dịch HNO\u003Csub\u003E3\u003C\u002Fsub\u003E thu được 0,01 mol khí NO là sản phẩm khử duy nhất.\u003Cbr\u003E Giá trị của m là\u003Cbr\u003E",[380,382,384,386],{"answer":381,"id":13}," 1,35.",{"answer":383,"id":16}," 0,54.",{"answer":385,"id":19}," 0,27.",{"answer":387,"id":22}," 0,81.\u003Cbr\u003E",32,{"question":390,"answers":391,"id":400,"right":22}," Cho 2,16 gam Al tác dụng với dung dịch HNO\u003Csub\u003E3\u003C\u002Fsub\u003E (dư). Sau khi phản ứng xảy ra hoàn toàn thu được 0,224 lít khí NO (ở đktc) và dung dịch X. Khối lượng muối khan thu được khi làm bay hơi dung dịch X là\u003Cbr\u003E",[392,394,396,398],{"answer":393,"id":13}," 6,12 gam.",{"answer":395,"id":16}," 4,02 gam.",{"answer":397,"id":19}," 17,04 gam.",{"answer":399,"id":22}," 19,14 gam.\u003Cbr\u003E",33,{"question":402,"answers":403,"id":412,"right":22}," Cho sơ đồ các phản ứng sau:\u003Cbr\u003E (a) X\u003Csub\u003E1\u003C\u002Fsub\u003E + H\u003Csub\u003E2\u003C\u002Fsub\u003EO → X\u003Csub\u003E2\u003C\u002Fsub\u003E + X\u003Csub\u003E3\u003C\u002Fsub\u003E↑ + H\u003Csub\u003E2\u003C\u002Fsub\u003E↑ (Điện phân dung dịch có màng ngăn).\u003Cbr\u003E (b) X\u003Csub\u003E2\u003C\u002Fsub\u003E + X\u003Csub\u003E4\u003C\u002Fsub\u003E → CaCO\u003Csub\u003E3\u003C\u002Fsub\u003E + Na\u003Csub\u003E2\u003C\u002Fsub\u003ECO\u003Csub\u003E3\u003C\u002Fsub\u003E + H\u003Csub\u003E2\u003C\u002Fsub\u003EO\u003Cbr\u003E (c) X\u003Csub\u003E2\u003C\u002Fsub\u003E + X\u003Csub\u003E3\u003C\u002Fsub\u003E → X\u003Csub\u003E1\u003C\u002Fsub\u003E + X\u003Csub\u003E5\u003C\u002Fsub\u003E + H\u003Csub\u003E2\u003C\u002Fsub\u003EO.\u003Cbr\u003E (d) X\u003Csub\u003E4\u003C\u002Fsub\u003E + X\u003Csub\u003E6\u003C\u002Fsub\u003E → CaSO\u003Csub\u003E4\u003C\u002Fsub\u003E + Na\u003Csub\u003E2\u003C\u002Fsub\u003ESO\u003Csub\u003E4\u003C\u002Fsub\u003E + CO\u003Csub\u003E2\u003C\u002Fsub\u003E + H\u003Csub\u003E2\u003C\u002Fsub\u003EO.\u003Cbr\u003E Các chất X\u003Csub\u003E5\u003C\u002Fsub\u003E, X\u003Csub\u003E6\u003C\u002Fsub\u003E thỏa mãn sơ đồ trên lần lượt là\u003Cbr\u003E",[404,406,408,410],{"answer":405,"id":13}," NaClO, H\u003Csub\u003E2\u003C\u002Fsub\u003ESO\u003Csub\u003E4\u003C\u002Fsub\u003E.",{"answer":407,"id":16}," Ca(HCO\u003Csub\u003E3\u003C\u002Fsub\u003E)\u003Csub\u003E2\u003C\u002Fsub\u003E, NaHSO\u003Csub\u003E4\u003C\u002Fsub\u003E.\u003Cbr\u003E",{"answer":409,"id":19}," Ca(HCO\u003Csub\u003E3\u003C\u002Fsub\u003E)\u003Csub\u003E2\u003C\u002Fsub\u003E, H\u003Csub\u003E2\u003C\u002Fsub\u003ESO\u003Csub\u003E4\u003C\u002Fsub\u003E.",{"answer":411,"id":22}," NaClO, NaHSO\u003Csub\u003E4\u003C\u002Fsub\u003E.\u003Cbr\u003E",34,{"question":414,"answers":415,"id":424,"right":13}," Theo TCVN 5502: 2003, dựa vào độ cứng của nước (được xác định bằng tổng hàm lượng Ca\u003Csup\u003E2\u003C\u002Fsup\u003E\u003Csup\u003E+\u003C\u002Fsup\u003E và Mg\u003Csup\u003E2\u003C\u002Fsup\u003E\u003Csup\u003E+\u003C\u002Fsup\u003E quy đổi về khối lượng CaCO\u003Csub\u003E3\u003C\u002Fsub\u003E, có trong 1 lít nước), người ta có thể phân nước thành 4 loại:\u003Cbr\u003E \u003Ctable\u003E\u003Ctr\u003E\u003Ctd\u003EPhân loại nước\u003C\u002Ftd\u003E\u003Ctd\u003EMềm\u003C\u002Ftd\u003E\u003Ctd\u003EHơi cứng\u003C\u002Ftd\u003E\u003Ctd\u003ECứng\u003C\u002Ftd\u003E\u003Ctd\u003ERất cứng\u003C\u002Ftd\u003E\u003C\u002Ftr\u003E\u003Ctr\u003E\u003Ctd\u003EĐộ cứng (mg CaCO\u003Csub\u003E3\u003C\u002Fsub\u003E\u002Flít)\u003C\u002Ftd\u003E\u003Ctd\u003E0 - 50\u003C\u002Ftd\u003E\u003Ctd\u003E50 - 150\u003C\u002Ftd\u003E\u003Ctd\u003E150 - 300\u003C\u002Ftd\u003E\u003Ctd\u003E&gt;300\u003C\u002Ftd\u003E\u003C\u002Ftr\u003E\u003C\u002Ftable\u003E\u003Cbr\u003E Từ một mẫu nước có chứa các ion (Mg\u003Csup\u003E2\u003C\u002Fsup\u003E\u003Csup\u003E+\u003C\u002Fsup\u003E, Ca\u003Csup\u003E2\u003C\u002Fsup\u003E\u003Csup\u003E+\u003C\u002Fsup\u003E, SO\u003Csub\u003E4\u003C\u002Fsub\u003E2\u003Csup\u003E-\u003C\u002Fsup\u003E 0,0004M, HCO\u003Csub\u003E3\u003C\u002Fsub\u003E\u003Csup\u003E-\u003C\u002Fsup\u003E 0,00042M, Cl\u003Csup\u003E-\u003C\u002Fsup\u003E 0,0003M), người ta có thể tính được giá trị độ cứng của mẫu nước. Hãy chọn nhận định đúng trong các nhận định sau\u003Cbr\u003E",[416,418,420,422],{"answer":417,"id":13}," Độ cứng của nước là 76 mg\u002Fl. Mẫu nước thuộc loại nước hơi cứng.\u003Cbr\u003E",{"answer":419,"id":16}," Độ cứng của nước là 152 mg\u002Fl. Mẫu nước thuộc loại nước cứng.\u003Cbr\u003E",{"answer":421,"id":19}," Độ cứng của nước là 40 mg\u002Fl. Mẫu nước thuộc loại nước mềm.\u003Cbr\u003E",{"answer":423,"id":22}," Độ cứng của nước là 400 mg\u002Fl. Mẫu nước thuộc loại nước rất cứng.\u003Cbr\u003E",35,{"question":426,"answers":427,"id":435,"right":22}," Cho các phát biểu sau:\u003Cbr\u003E (a) Cho dung dịch NH\u003Csub\u003E3\u003C\u002Fsub\u003E vào dung dịch AlCl\u003Csub\u003E3\u003C\u002Fsub\u003E có xuất hiện kết tủa.\u003Cbr\u003E (b) Nhiệt phân hoàn toàn Cu(NO\u003Csub\u003E3\u003C\u002Fsub\u003E)\u003Csub\u003E2\u003C\u002Fsub\u003E tạo thành Cu.\u003Cbr\u003E (c) Hỗn hợp Na\u003Csub\u003E2\u003C\u002Fsub\u003EO và Al (tỉ lệ mol 1:1) tan hết trong nước dư.\u003Cbr\u003E (d) Trong công nghiệp dược phẩm, NaHCO\u003Csub\u003E3\u003C\u002Fsub\u003E được dùng để điều chế thuốc đau dạ dày.\u003Cbr\u003E (e) Trong công nghiệp, Al được sản xuất bằng phương pháp điện phân nóng chảy AlCl\u003Csub\u003E3\u003C\u002Fsub\u003E.\u003Cbr\u003E Số phát biểu đúng là\u003Cbr\u003E",[428,430,432,433],{"answer":429,"id":13}," 4.",{"answer":431,"id":16}," 5.",{"answer":226,"id":19},{"answer":434,"id":22}," 3.\u003Cbr\u003E",36,{"question":437,"answers":438,"id":447,"right":16}," Khối lượng dung dịch HNO\u003Csub\u003E3\u003C\u002Fsub\u003E 6,3% loãng tối thiểu để hòa tan hoàn toàn hỗn hợp gồm 10,5g Fe và 2,7g Al là bao nhiêu? Biết sản phẩm khử chỉ là NO.\u003Cbr\u003E",[439,441,443,445],{"answer":440,"id":13}," 420g",{"answer":442,"id":16}," 900g",{"answer":444,"id":19}," 700g",{"answer":446,"id":22}," 2700g\u003Cbr\u003E",37,{"question":449,"answers":450,"id":459,"right":19}," Nung hỗn hợp gồm 0,12 mol Al và 0,04 mol Fe\u003Csub\u003E3\u003C\u002Fsub\u003EO\u003Csub\u003E4\u003C\u002Fsub\u003E một thời gian, thu được hỗn hợp rắn X. Hòa tan hoàn toàn X trong dung dịch HCl dư thu được 0,15 mol khí H\u003Csub\u003E2\u003C\u002Fsub\u003E và m gam muối. Giá trị của m là\u003Cbr\u003E",[451,453,455,457],{"answer":452,"id":13}," 34,10.",{"answer":454,"id":16}," 32,58.",{"answer":456,"id":19}," 31,97.",{"answer":458,"id":22}," 33,39.\u003Cbr\u003E",38,{"question":461,"answers":462,"id":471,"right":13}," Hàn nhiệt là phương pháp hàn dựa trên cơ sở của phản ứng tỏa nhiệt giữa một oxit kim loại với một kim loại khác có ái lực hóa học với oxi mạnh hơn. Thông dụng nhất là phản ứng giữa nhôm và oxit sắt từ (Fe\u003Csub\u003E3\u003C\u002Fsub\u003EO\u003Csub\u003E4\u003C\u002Fsub\u003E). Phản ứng xảy ra khi nung nóng một lượng nhỏ hỗn hợp đến nhiệt độ khoảng 1200 - 1300°C, sau đó phản ứng tiếp tục được duy trì nhờ nhiệt độ của phản ứng và lan nhanh ra toàn khối hỗn hợp làm nhiệt độ tăng lên đến 3000°C, nung nóng chảy sắt tạo thành thép lỏng và làm nóng chảy các tạp chất tạo thành xỉ lỏng.\u003Cbr\u003E \u003Cimg src=\"\u002F2023\u002Fhoa340.png\"\u003E\u003Cbr\u003E 1. Chi tiết hàn; 2. Khuôn; 3. Hệ thống rót; 4. Nồi chứa; 5. Xỉ; 6. Thép lỏng\u003Cbr\u003E Tiến hành mở lỗ rót ở đáy nồi phản ứng để rót thép lỏng vào khuôn. Thép lỏng có nhiệt độ cao nung chảy mép hàn, sau đó đông đặc tạo thành mối hàn. Cho biết khối lượng riêng của sắt là 7,87 g\u002Fcm³ và lượng sắt trong mối hàn bằng 90% lượng sắt được điều chế ra và các chất được lấy đúng theo hệ số tỉ lượng. Khối lượng gần nhất của hỗn hợp tecmit cần lấy để có thể hàn được vết nứt gãy của đường ray có thể tích là 10 cm³ là\u003Cbr\u003E",[463,465,467,469],{"answer":464,"id":13}," 158 gam.",{"answer":466,"id":16}," 138 gam.",{"answer":468,"id":19}," 128 gam.",{"answer":470,"id":22}," 148 gam.\u003Cbr\u003E",39,"https:\u002F\u002Fazota.vn\u002Fde-thi\u002Fkhj0xz","3"],"uses":{"params":["subject","id"]}}]}
