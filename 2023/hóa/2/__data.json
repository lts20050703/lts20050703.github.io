03C\u002Fsub\u003E → X → Y → Al.\u003Cbr\u003E Trong sơ đồ trên, mỗi mũi tên là một phản ứng, các chất X, Y lần lượt là những chất nào sau đây?\u003Cbr\u003E",[396,398,400,402],{"answer":397,"id":13}," Al\u003Csub\u003E2\u003C\u002Fsub\u003EO\u003Csub\u003E3\u003C\u002Fsub\u003E và Al(OH)\u003Csub\u003E3\u003C\u002Fsub\u003E",{"answer":399,"id":16}," Al(OH)\u003Csub\u003E3\u003C\u002Fsub\u003E và Al\u003Csub\u003E2\u003C\u002Fsub\u003EO\u003Csub\u003E3\u003C\u002Fsub\u003E\u003Cbr\u003E",{"answer":401,"id":19}," Al(OH)\u003Csub\u003E3\u003C\u002Fsub\u003E và NaAlO\u003Csub\u003E2\u003C\u002Fsub\u003E",{"answer":403,"id":22}," NaAlO\u003Csub\u003E2\u003C\u002Fsub\u003E và Al(OH)\u003Csub\u003E3\u003C\u002Fsub\u003E\u003Cbr\u003E",33,{"question":406,"answers":407,"id":414,"right":13}," Thực hiện các thí nghiệm sau:\u003Cbr\u003E *(a) Cho dung dịch KHSO\u003Csub\u003E4\u003C\u002Fsub\u003E vào dung dịch Ba(HCO\u003Csub\u003E3\u003C\u002Fsub\u003E)\u003Csub\u003E2\u003C\u002Fsub\u003E.\u003Cbr\u003E *(b) Cho dung dịch NaOH vào dung dịch Ca(HCO\u003Csub\u003E3\u003C\u002Fsub\u003E)\u003Csub\u003E2\u003C\u002Fsub\u003E.\u003Cbr\u003E *(c) Cho dung dịch NaHCO\u003Csub\u003E3\u003C\u002Fsub\u003E vào dung dịch CaCl\u003Csub\u003E2\u003C\u002Fsub\u003E đun nóng.\u003Cbr\u003E *(d) Cho hỗn hợp Cu và Fe\u003Csub\u003E3\u003C\u002Fsub\u003EO\u003Csub\u003E4\u003C\u002Fsub\u003E (tỉ lệ mol 2:1) vào lượng dư dung dịch HCl.\u003Cbr\u003E *(e) Cho kim loại Ba vào dung dịch CuCl\u003Csub\u003E2\u003C\u002Fsub\u003E.\u003Cbr\u003E (f) Cho hỗn hợp Cu và KNO\u003Csub\u003E3\u003C\u002Fsub\u003E (tỉ lệ mol 3:2) vào dung dịch H\u003Csub\u003E2\u003C\u002Fsub\u003ESO\u003Csub\u003E4\u003C\u002Fsub\u003E loãng dư.\u003Cbr\u003E Sau khi các phản ứng kết thúc, số thí nghiệm có chất rắn sau phản ứng hay là\u003Cbr\u003E",[408,409,411,412],{"answer":377,"id":13},{"answer":410,"id":16}," 4.",{"answer":367,"id":19},{"answer":413,"id":22}," 6.\u003Cbr\u003E",34,{"question":416,"answers":417,"id":