03Csub>4\u003C/sub>.5H\u003Csub>2\u003C/sub>O.",{"answer":66,"id":22}," CaCl\u003Csub>2\u003C/sub>.6H\u003Csub>2\u003C/sub>O.\u003Cbr>",4,{"question":69,"answers":70,"id":79,"right":19}," Oxit nào của crom khi tan trong nước thu được hỗn hợp 2 axit?\u003Cbr>",[71,73,75,77],{"answer":72,"id":13}," Cr\u003Csub>2\u003C/sub>O.",{"answer":74,"id":16}," Cr\u003Csub>2\u003C/sub>O\u003Csub>3\u003C/sub>.",{"answer":76,"id":19}," CrO\u003Csub>3\u003C/sub>.",{"answer":78,"id":22}," CrO.\u003Cbr>",5,{"question":81,"answers":82,"id":91,"right":22}," Dung dịch chất nào sau đây có pH > 7?\u003Cbr>",[83,85,87,89],{"answer":84,"id":13}," NaNO\u003Csub>3\u003C/sub>.",{"answer":86,"id":16}," KCl.",{"answer":88,"id":19}," H\u003Csub>2\u003C/sub>SO\u003Csub>4\u003C/sub>.",{"answer":90,"id":22}," Ca(OH)\u003Csub>2\u003C/sub>\u003Cbr>",6,{"question":93,"answers":94,"id":103,"right":13}," Fe dư tác dụng với dung dịch HNO\u003Csub>3\u003C/sub> đặc, nóng thì thu được muối nào?\u003Cbr>",[95,97,99,101],{"answer":96,"id":13}," Fe(NO\u003Csub>3\u003C/sub>)\u003Csub>2\u003C/sub>.",{"answer":98,"id":16}," Fe(NO\u003Csub>3\u003C/sub>)\u003Csub>3\u003C/sub>.",{"answer":100,"id":19}," Fe(NO\u003Csub>3\u003C/sub>)\u003Csub>2\u003C/sub> và Fe(NO\u003Csub>3\u003C/sub>)\u003Csub>3\u003C/sub>.",{"answer":102,"id":22}," FeNO\u003Csub>3\u003C/sub>.\u003Cbr>",7,{"question":105,"answers":106,"id":114,"right":13}," Kim loại Al tan hết trong lượng dư dung dịch nào sau đây sinh ra khí H\u003Csub>2\u003C/sub>?\u003Cbr>",[107,109,110,112],{"answer":108,"id":13}," NaOH",{"answer":84,"id":16},{"answer":111,"id":19}," NaCl.",{"answer":113,"id":22}," CuCl\u003Csub>2\u003C/sub>.\u003Cbr>",8,{"question":116,"answers":117,"id":126,"right":19}," Kim loại nào sau đây là kim loại kiềm?\u003Cbr>",[118,120,122,124],{"answer":119,"id":13}," Mg.",{"answer":121,"id":16}," Ag.",{"answer":123,"id":19}," K.",{"answer":125,"id":22}," Ni\u003Cbr>",9,{"question":128,"answers":129,"id":136,"right":13}," Hòa tan hỗn hợp gồm Fe\u003Csub>2\u003C/sub>O\u003Csub>3\u003C/sub> và Fe(OH)\u003Csub>3\u003C/sub> trong lượng dư dung dịch H\u003Csub>2\u003C/sub>SO\u003Csub>4\u003C/sub> loãng, sau phản ứng thu được dung dịch chứa muối nào sau đây?\u003Cbr>",[130,131,133,134],{"answer":18,"id":13},{"answer":132,"id":16}," FeS.",{"answer":12,"id":19},{"answer":135,"id":22}," FeSO\u003Csub>3\u003C/sub>.\u003Cbr>",10,{"question":138,"answers":139,"id":148,"right":13}," Hòa tan m (gam) hỗn hợp Na\u003Csub>2\u003C/sub>CO\u003Csub>3\u003C/sub>, K\u003Csub>2\u003C/sub>CO\u003Csub>3\u003C/sub> và CaCO\u003Csub>3\u003C/sub> vào dung dịch chứa HCl dư thu 4,48 (lít) CO\u003Csub>2\u003C/sub> (đktc).\u003Cbr> Cô cạn dd sau phản ứng thu được 23,6 gam muối khan. Tìm m?\u003Cbr>",[140,142,144,146],{"answer":141,"id":13}," 21.4 gam",{"answer":143,"id":16}," 10.7 gam",{"answer":145,"id":19}," 42.8 gam",{"answer":147,"id":22}," 32.1 gam\u003Cbr>",11,{"question":150,"answers":151,"id":160,"right":19}," Hòa tan hoàn toàn 12 gam hỗn hợp muối khan FeSO\u003Csub>4\u003C/sub> và Fe\u003Csub>2\u003C/sub>(SO\u003Csub>4\u003C/sub>)\u003Csub>3\u003C/sub> thu được dd A; dung dịch A có thể phản ứng hoàn toàn với 2,212 gam KMnO\u003Csub>4\u003C/sub> trong môi trường H\u003Csub>2\u003C/sub>SO\u003Csub>4\u003C/sub>. Thành phần % (m) của Fe\u003Csub>2\u003C/sub>(SO\u003Csub>4\u003C/sub>)\u003Csub>3\u003C/sub> gần nhất với giá trị:\u003Cbr>",[152,154,156,158],{"answer":153,"id":13}," 22,0.",{"answer":155,"id":16}," 10,0.",{"answer":157,"id":19}," 12,0.",{"answer":159,"id":22}," 7,6.\u003Cbr>",12,{"question":162,"answers":163,"id":172,"right":19}," Cho từ từ dung dịch HCl vào dung dịch chứa hỗn hợp KOH và KAlO\u003Csub>2\u003C/sub>, sự biến thiên lượng kết tủa Al(OH)\u003Csub>3\u003C/sub> tạo thành trong thí nghiệm được biểu diễn trên đồ thị sau:\u003Cbr> \u003Cimg src=\"/img/2023/hoa214.png\">\u003Cbr> Dựa vào đồ thị trên. Phát biểu nào đúng.\u003Cbr>",[164,166,168,170],{"answer":165,"id":13}," Số mol KOH trong dung dịch là (4a+b) mol.\u003Cbr>",{"answer":167,"id":16}," Sau khi kết tủa tan hết, trong dung dịch có 3 muối.\u003Cbr>",{"answer":169,"id":19}," Số mol KAlO\u003Csub>2\u003C/sub> trong dung dịch là a mol.\u003Cbr>",{"answer":171,"id":22}," Nếu thay dung dịch HCl bằng khí CO\u003Csub>2\u003C/sub> thì ta vẫn thu kết quả như đồ thị trên.\u003Cbr>",13,{"question":174,"answers":175,"id":184,"right":19}," Cho luồng khí H\u003Csub>2\u003C/sub> dư qua hỗn hợp các oxit CuO, FeO, ZnO và Al\u003Csub>2\u003C/sub>O\u003Csub>3\u003C/sub> nung ở nhiệt độ cao. Sau phản ứng, hỗn hợp chất rắn còn lại là\u003Cbr>",[176,178,180,182],{"answer":177,"id":13}," Cu, FeO, ZnO, Al\u003Csub>2\u003C/sub>O\u003Csub>3\u003C/sub>.",{"answer":179,"id":16}," Cu, Fe, ZnO, Al\u003Csub>2\u003C/sub>O\u003Csub>3\u003C/sub>.\u003Cbr>",{"answer":181,"id":19}," Cu, Fe, Zn, Al\u003Csub>2\u003C/sub>O\u003Csub>3\u003C/sub>.",{"answer":183,"id":22}," Cu, Fe, Zn, Al.\u003Cbr>",14,{"question":186,"answers":187,"id":195,"right":16}," Hêmatit là một trong những quặng quan trọng của sắt. Thành phần chính của quặng là.\u003Cbr>",[188,189,191,193],{"answer":42,"id":13},{"answer":190,"id":16}," Fe\u003Csub>2\u003C/sub>O\u003Csub>3\u003C/sub>.",{"answer":192,"id":19}," Fe\u003Csub>3\u003C/sub>O\u003Csub>4\u003C/sub>.",{"answer":194,"id":22}," FeCO\u003Csub>3\u003C/sub>.\u003Cbr>",15,{"question":197,"answers":198,"id":207,"right":19}," Những kim loại nào sau đây có thể được điều chế từ oxit, bằng phương pháp nhiệt luyện nhờ chất khử CO?\u003Cbr>",[199,201,203,205],{"answer":200,"id":13}," Fe, Ag, Al.",{"answer":202,"id":16}," Pb, Mg, Fe.",{"answer":204,"id":19}," Fe, Mn, Ni.",{"answer":206,"id":22}," Ba, Cu, Ca .\u003Cbr>",16,{"question":209,"answers":210,"id":219,"right":19}," Al(OH)\u003Csub>3\u003C/sub> là hidroxit lưỡng tính, phản ứng nào sau đây chứng minh được tính chất đó?\u003Cbr> (1) Al(OH)\u003Csub>3\u003C/sub> + 3HCl → AlCl\u003Csub>3\u003C/sub> + 3H\u003Csub>2\u003C/sub>O\u003Cbr> (2) Al\u003Csub>2\u003C/sub>(SO\u003Csub>4\u003C/sub>)\u003Csub>3\u003C/sub>+6NH\u003Csub>3\u003C/sub>+6H\u003Csub>2\u003C/sub>O→2Al(OH)\u003Csub>3\u003C/sub> +3 (NH\u003Csub>4\u003C/sub>)\u003Csub>2\u003C/sub>SO\u003Csub>4\u003C/sub>\u003Cbr> (3) 2Al(OH)\u003Csub>3\u003C/sub> → Al\u003Csub>2\u003C/sub>O\u003Csub>3\u003C/sub> + 3H\u003Csub>2\u003C/sub>O\u003Cbr> (4) NaAlO\u003Csub>2\u003C/sub>+ HCl + H\u003Csub>2\u003C/sub>O → Al(OH)\u003Csub>3\u003C/sub> + NaCl\u003Cbr> (5) Al(OH)\u003Csub>3\u003C/sub> + KOH → KAlO\u003Csub>2\u003C/sub> + 2H\u003Csub>2\u003C/sub>O\u003Cbr>",[211,213,215,217],{"answer":212,"id":13}," 1, 2.",{"answer":214,"id":16}," 1, 2, 4.",{"answer":216,"id":19}," 1, 5.",{"answer":218,"id":22}," 1, 3, 4.\u003Cbr>",17,{"question":221,"answers":222,"id":231,"right":16}," Cho m gam hỗn hợp Al và Na vào nước dư, sau khi các phản ứng xảy ra hoàn toàn, thu được 2,24 lít khí\u003Cbr> H\u003Csub>2\u003C/sub> (đktc) và 2,35 gam chất rắn không tan. Giá trị của m là\u003Cbr>",[223,225,227,229],{"answer":224,"id":13}," 4,35",{"answer":226,"id":16}," 4,85",{"answer":228,"id":19}," 6,95",{"answer":230,"id":22}," 3,70\u003Cbr>",18,{"question":233,"answers":234,"id":243,"right":22}," Một cốc nước chứa: a mol Ca\u003Csup>2\u003C/sup>\u003Csup>+\u003C/sup>, b mol Mg\u003Csup>2\u003C/sup>\u003Csup>+\u003C/sup>, c mol Cl\u003Csup>-\u003C/sup> và d mol HCO\u003Csub>3\u003C/sub>. Biểu thức liên hệ giữa a, b, c,",[235,237,239,241],{"answer":236,"id":13}," a + b = c + d",{"answer":238,"id":16}," 3a + 3b = c + d",{"answer":240,"id":19},"2a + 2b - c + d = 0",{"answer":242,"id":22}," 2a + 2b - c - d = 0\u003Cbr>",19,{"question":245,"answers":246,"id":252,"right":16}," Hợp chất nào của crom có tính lưỡng tính?\u003Cbr>",[247,248,249,250],{"answer":72,"id":13},{"answer":74,"id":16},{"answer":76,"id":19},{"answer":251,"id":22}," K\u003Csub>2\u003C/sub>Cr\u003Csub>2\u003C/sub>O\u003Csub>7\u003C/sub>.\u003Cbr>",20,{"question":254,"answers":255,"id":264,"right":16}," Khi nhiệt kế thủy ngân bị vỡ, ta cần sử dụng hóa chất nào sau đây để khử độc thủy ngân?\u003Cbr>",[256,258,260,262],{"answer":257,"id":13}," muối ăn",{"answer":259,"id":16}," Lưu huỳnh",{"answer":261,"id":19}," Vôi sống",{"answer":263,"id":22}," Cacbon\u003Cbr>",21,{"question":266,"answers":267,"id":276,"right":13}," Đổ từ từ dd chứa 0,25 mol HCl vào dd A gồm 0,2 mol NaHCO\u003Csub>3\u003C/sub> và 0,15 mol Na\u003Csub>2\u003C/sub>CO\u003Csub>3\u003C/sub>. Tìm VCO\u003Csub>2\u003C/sub> (đktc).\u003Cbr>",[268,270,272,274],{"answer":269,"id":13}," 2,24 lít",{"answer":271,"id":16}," 3,36 lít",{"answer":273,"id":19}," 4,48 lít",{"answer":275,"id":22}," 5,6 lít\u003Cbr>",22,{"question":278,"answers":279,"id":288,"right":16}," Cho sắt phản ứng với dung dịch HNO\u003Csub>3\u003C/sub> đặc, nóng thu được một chất khí màu nâu đỏ. Chất khí đó là\u003Cbr>",[280,282,284,286],{"answer":281,"id":13}," N\u003Csub>2\u003C/sub>O.",{"answer":283,"id":16}," NO\u003Csub>2\u003C/sub>.",{"answer":285,"id":19}," NH\u003Csub>3\u003C/sub>.",{"answer":287,"id":22}," N\u003Csub>2\u003C/sub>.\u003Cbr>",23,{"question":290,"answers":291,"id":300,"right":19}," Cho các dung dịch: KOH, NaCl, H\u003Csub>2\u003C/sub>SO\u003Csub>4\u003C/sub> loãng, HNO\u003Csub>3\u003C/sub> đặc nguội, CuSO\u003Csub>4\u003C/sub>, HCl. Có bao nhiêu dung dịch phản ứng được kim loại nhôm\u003Cbr>",[292,294,296,298],{"answer":293,"id":13}," 2",{"answer":295,"id":16}," 3",{"answer":297,"id":19}," 4",{"answer":299,"id":22}," 5\u003Cbr>",24,{"question":302,"answers":303,"id":312,"right":16}," Dãy gồm các chất đều có thể làm mất tính cứng tạm thời của nước là:\u003Cbr>",[304,306,308,310],{"answer":305,"id":13}," HCl, NaOH, Na\u003Csub>2\u003C/sub>CO\u003Csub>3\u003C/sub>.",{"answer":307,"id":16}," NaOH, Na\u003Csub>3\u003C/sub>PO\u003Csub>4\u003C/sub>, Na\u003Csub>2\u003C/sub>CO\u003Csub>3\u003C/sub>.\u003Cbr>",{"answer":309,"id":19}," KCl, Ca(OH)\u003Csub>2\u003C/sub>, Na\u003Csub>2\u003C/sub>CO\u003Csub>3\u003C/sub>.",{"answer":311,"id":22}," HCl, Ca(OH)\u003Csub>2\u003C/sub>, Na\u003Csub>2\u003C/sub>CO\u003Csub>3\u003C/sub>.\u003Cbr>",25,{"question":314,"answers":315,"id":324,"right":16}," Phèn chua có công thức nào ?\u003Cbr>",[316,318,320,322],{"answer":317,"id":13}," (NH\u003Csub>4\u003C/sub>)\u003Csub>2\u003C/sub>SO\u003Csub>4\u003C/sub>.Fe\u003Csub>2\u003C/sub>(SO\u003Csub>4\u003C/sub>)\u003Csub>3\u003C/sub>.24H\u003Csub>2\u003C/sub>O",{"answer":319,"id":16}," K\u003Csub>2\u003C/sub>SO\u003Csub>4\u003C/sub>.Al\u003Csub>2\u003C/sub>(SO\u003Csub>4\u003C/sub>)\u003Csub>3\u003C/sub>.24H\u003Csub>2\u003C/sub>O\u003Cbr>",{"answer":321,"id":19}," CuSO\u003Csub>4\u003C/sub>.5H\u003Csub>2\u003C/sub>O",{"answer":323,"id":22}," (NH\u003Csub>4\u003C/sub>)\u003Csub>2\u003C/sub>SO\u003Csub>4\u003C/sub>.Al\u003Csub>2\u003C/sub>(SO\u003Csub>4\u003C/sub>)\u003Csub>3\u003C/sub>.24H\u003Csub>2\u003C/sub>O\u003Cbr>",26,{"question":326,"answers":327,"id":334,"right":19}," Khi nung hỗn hợp các chất Fe(NO\u003Csub>3\u003C/sub>)\u003Csub>2\u003C/sub>, Fe(OH)\u003Csub>3\u003C/sub> và FeCO\u003Csub>3\u003C/sub> trong không khí đến khối lượng không đổi, thu được một chất rắn là\u003Cbr>",[328,330,331,332],{"answer":329,"id":13}," Fe.",{"answer":192,"id":16},{"answer":190,"id":19},{"answer":333,"id":22}," FeO.\u003Cbr>",27,{"question":336,"answers":337,"id":346,"right":19}," Natri cacbonat là hóa chất quan trọng trong công nghiệp thủy tinh, bột giặt, phẩm nhuộm, giấy, sợi. Công thức của natri cacbonat là\u003Cbr>",[338,340,342,344],{"answer":339,"id":13}," MgCO\u003Csub>3\u003C/sub>.",{"answer":341,"id":16}," NaHCO\u003Csub>3\u003C/sub>.",{"answer":343,"id":19}," Na\u003Csub>2\u003C/sub>CO\u003Csub>3\u003C/sub>.",{"answer":345,"id":22}," CaCO\u003Csub>3\u003C/sub>.\u003Cbr>",28,{"question":348,"answers":349,"id":358,"right":19}," Kim loại nặng là những kim loại có khối lượng riêng >5g/cm\u003Csup>3\u003C/sup> như Thủy ngân Hg, Cadimi Cd, chì Pb, Asen As, Thiếc Sn, Crom Cr, đồng Cu, Kẽm Zn, mangan Mn, ... thường không tham gia hoặc ít tham gia vào quá trình sinh hóa của các thể sinh vật và tích lũy trong cơ thể sinh vật. Do độ hòa tan trong nước của các kim loại này cao nên chúng có thể hấp thụ tốt vào cơ thể sinh vật, nếu sự tích lũy diễn ra với nồng độ cao và vượt quá giới hạn cho phép có thể gây ra nhiễm độc và tổn hại trầm trọng đến cơ thể sinh vật... Em hãy đề xuất một chất hóa học rẻ tiền có thể loại bỏ các ion kim loại trên trong nguồn nước.\u003Cbr>",[350,352,354,356],{"answer":351,"id":13}," NaCl",{"answer":353,"id":16}," CaCO\u003Csub>3\u003C/sub>",{"answer":355,"id":19}," Ca(OH)\u003Csub>2\u003C/sub>",{"answer":357,"id":22}," KNO\u003Csub>3\u003C/sub>.\u003Cbr>",29,{"question":360,"answers":361,"id":370,"right":16}," Có bao nhiêu thí nghiệm sau thu được kết tủa Al(OH)\u003Csub>3\u003C/sub>:\u003Cbr> (1) Cho từ từ dung dịch NaOH dư vào dd AlCl\u003Csub>3\u003C/sub>.\u003Cbr> (2) Cho nhanh dung dịch HCl dư vào dd AlCl\u003Csub>3\u003C/sub>\u003Cbr> *(3) Cho dung dịch NH\u003Csub>3\u003C/sub> dư vào dung dịch AlCl\u003Csub>3\u003C/sub>.\u003Cbr> (4) Cho dung dịch HCl dư vào dung dịch NaAlO\u003Csub>2\u003C/sub>.\u003Cbr> *(5) Thổi CO\u003Csub>2\u003C/sub> dư vào dung dịch NaAlO\u003Csub>2\u003C/sub>.\u003Cbr>",[362,364,366,368],{"answer":363,"id":13}," 1",{"answer":365,"id":16}," 2.",{"answer":367,"id":19}," 3.",{"answer":369,"id":22}," 4\u003Cbr>",30,{"question":372,"answers":373,"id":380,"right":19}," Cho các phát biểu sau:\u003Cbr> *(a) Kim loại Fe tan hoàn toàn trong dung dịch HNO\u003Csub>3\u003C/sub> đặc, nóng.\u003Cbr> *(b) Các kim loại K, Na, Ba đều tác dụng với nước ở điều kiện thường.\u003Cbr> *(c) Nhúng thanh kim loại Zn vào dung dịch Cu(NO\u003Csub>3\u003C/sub>)\u003Csub>2\u003C/sub> có xảy ra ăn mòn điện hóa học.\u003Cbr> (d) Cho dung dịch Na\u003Csub>2\u003C/sub>SO\u003Csub>4\u003C/sub> loãng vào dung dịch BaCl\u003Csub>2\u003C/sub> thu được kết tủa gồm hai chất.\u003Cbr> *(e) Cho a mol P\u003Csub>2\u003C/sub>O\u003Csub>5\u003C/sub> vào dung dịch chứa 4,5a mol NaOH thu được dung dịch chứa hỗn hợp muối.\u003Cbr> *(f) Cu tan trong dung dịch FeCl\u003Csub>3\u003C/sub> dư.\u003Cbr> Số phát biểu đúng là\u003Cbr>",[374,375,376,378],{"answer":367,"id":13},{"answer":365,"id":16},{"answer":377,"id":19}," 5.",{"answer":379,"id":22}," 4.\u003Cbr>",31,{"question":382,"answers":383,"id":392,"right":19}," Cho m gam hỗn hợp MgCO\u003Csub>3\u003C/sub>, Na\u003Csub>2\u003C/sub>CO\u003Csub>3\u003C/sub>, K\u003Csub>2\u003C/sub>CO\u003Csub>3\u003C/sub> và CaCO\u003Csub>3\u003C/sub> tác dụng hoàn toàn với dung dịch HCl dư thấy có V lít khí cacbonic thoát ra. Đem cô cạn dung dịch sau phản ứng thì thu được (m+4,4) gam muối khan. Giá trị của V là\u003Cbr>",[384,386,388,390],{"answer":385,"id":13}," 17,92.",{"answer":387,"id":16}," 6,72.",{"answer":389,"id":19}," 8,96.",{"answer":391,"id":22}," 11,2.\u003Cbr>",32,{"question":394,"answers":395,"id":404,"right":16}," Cho sơ đồ phản ứng: Al\u003Csub>2\u003C/sub>(SO\u003Csub>4\u003C/sub>)\u003Csub>3\u003C/sub> → X → Y → Al.\u003Cbr> Trong sơ đồ trên, mỗi mũi tên là một phản ứng, các chất X, Y lần lượt là những chất nào sau đây?\u003Cbr>",[396,398,400,402],{"answer":397,"id":13}," Al\u003Csub>2\u003C/sub>O\u003Csub>3\u003C/sub> và Al(OH)\u003Csub>3\u003C/sub>",{"answer":399,"id":16}," Al(OH)\u003Csub>3\u003C/sub> và Al\u003Csub>2\u003C/sub>O\u003Csub>3\u003C/sub>\u003Cbr>",{"answer":401,"id":19}," Al(OH)\u003Csub>3\u003C/sub> và NaAlO\u003Csub>2\u003C/sub>",{"answer":403,"id":22}," NaAlO\u003Csub>2\u003C/sub> và Al(OH)\u003Csub>3\u003C/sub>\u003Cbr>",33,{"question":406,"answers":407,"id":414,"right":13}," Thực hiện các thí nghiệm sau:\u003Cbr> *(a) Cho dung dịch KHSO\u003Csub>4\u003C/sub> vào dung dịch Ba(HCO\u003Csub>3\u003C/sub>)\u003Csub>2\u003C/sub>.\u003Cbr> *(b) Cho dung dịch NaOH vào dung dịch Ca(HCO\u003Csub>3\u003C/sub>)\u003Csub>2\u003C/sub>.\u003Cbr> *(c) Cho dung dịch NaHCO\u003Csub>3\u003C/sub> vào dung dịch CaCl\u003Csub>2\u003C/sub> đun nóng.\u003Cbr> *(d) Cho hỗn hợp Cu và Fe\u003Csub>3\u003C/sub>O\u003Csub>4\u003C/sub> (tỉ lệ mol 2:1) vào lượng dư dung dịch HCl.\u003Cbr> *(e) Cho kim loại Ba vào dung dịch CuCl\u003Csub>2\u003C/sub>.\u003Cbr> (f) Cho hỗn hợp Cu và KNO\u003Csub>3\u003C/sub> (tỉ lệ mol 3:2) vào dung dịch H\u003Csub>2\u003C/sub>SO\u003Csub>4\u003C/sub> loãng dư.\u003Cbr> Sau khi các phản ứng kết thúc, số thí nghiệm có chất rắn sau phản ứng hay là\u003Cbr>",[408,409,411,412],{"answer":377,"id":13},{"answer":410,"id":16}," 4.",{"answer":367,"id":19},{"answer":413,"id":22}," 6.\u003Cbr>",34,{"question":416,"answers":417,"id":426,"right":19}," Trộn 6,48g Al với 20g Fe\u003Csub>2\u003C/sub>O\u003Csub>3\u003C/sub>. Thực hiện phản ứng nhiệt nhôm thu được chất rắn",[418,420,422,424],{"answer":419,"id":13}," 100%",{"answer":421,"id":16}," 85%",{"answer":423,"id":19}," 80%",{"answer":425,"id":22}," 83,3%\u003Cbr>",35,{"question":428,"answers":429,"id":438,"right":13}," Cần bao nhiêu tấn quặng manhetit chứa 80% Fe\u003Csub>3\u003C/sub>O\u003Csub>4\u003C/sub> để có thể luyện được 800 tấn gang có hàm lượng sắt 95%. Lượng sắt bị hao hụt trong sản xuất là 1%.\u003Cbr>",[430,432,434,436],{"answer":431,"id":13}," 1325,16 tấn.",{"answer":433,"id":16}," 3975,48 tấn.",{"answer":435,"id":19}," 131,90 tấn.",{"answer":437,"id":22}," 1060,13 tấn.\u003Cbr>",36,{"question":440,"answers":441,"id":450,"right":13}," Hòa tan hoàn hoàn m gam hh Na, Na\u003Csub>2\u003C/sub>O, Ba, BaO vào nước thì thu được dd Y và 0,02 mol H\u003Csub>2\u003C/sub>. Làm các thí nghiệm khi dẫn khí CO\u003Csub>2\u003C/sub> vào dung dịch Y cho ta bảng giá trị sau. Hãy tìm m?\u003Cbr> \u003Ctable>\u003Ctr>\u003Ctd>Mol CO\u003Csub>2\u003C/sub>\u003C/td>\u003Ctd>0.02\u003C/td>\u003Ctd>0.04\u003C/td>\u003Ctd>0.14\u003C/td>\u003C/tr>\u003Ctr>\u003Ctd>Khối lượng kết tủa\u003C/td>\u003Ctd>2a\u003C/td>\u003Ctd>4a\u003C/td>\u003Ctd>a\u003C/td>\u003C/tr>\u003C/table>\u003Cbr> Khối lượng kết tủa 2a 4a a\u003Cbr>",[442,444,446,448],{"answer":443,"id":13}," 7.97 gam",{"answer":445,"id":16}," 15.94 gam",{"answer":447,"id":19}," 3.985 gam",{"answer":449,"id":22}," 11.955 gam\u003Cbr>",37,{"question":452,"answers":453,"id":462,"right":13}," Hỗn hợp E gồm Fe, Fe\u003Csub>3\u003C/sub>O\u003Csub>4\u003C/sub>, Fe\u003Csub>2\u003C/sub>O\u003Csub>3\u003C/sub> và Fe(NO\u003Csub>3\u003C/sub>)\u003Csub>2\u003C/sub>. Nung 23,84 gam E trong môi trường trơ thu được chất rắn X (chỉ gồm Fe và các oxit) và 0,12 mol khí NO\u003Csub>2\u003C/sub>. Hòa tan hết X trong dung dịch HCl nồng độ 3,65% thu được 672 ml khí H\u003Csub>2\u003C/sub> và dung dịch Y chỉ chứa muối. Cho tiếp dung dịch AgNO\u003Csub>3\u003C/sub> dư vào Y thu được 102,3 gam kết tủa gồm Ag và AgCl. Biết các phản ứng xảy ra hoàn toàn. Nồng độ phần trăm của muối FeCl\u003Csub>2\u003C/sub> trong Y gần nhất với giá trị nào sau đây?\u003Cbr>",[454,456,458,460],{"answer":455,"id":13}," 3,08%.",{"answer":457,"id":16}," 3,58%.",{"answer":459,"id":19}," 3,12%.",{"answer":461,"id":22}," 2,84%.\u003Cbr>",38,"https://azota.vn/de-thi/h1wivg","2"],"uses":{"params":["subject","id"]}}]}
