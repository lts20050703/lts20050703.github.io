id":16}," 1, 2, 4.",{"answer":216,"id":19}," 1, 5.",{"answer":218,"id":22}," 1, 3, 4.\u003Cbr\u003E",17,{"question":221,"answers":222,"id":231,"right":16}," Cho m gam hỗn hợp Al và Na vào nước dư, sau khi các phản ứng xảy ra hoàn toàn, thu được 2,24 lít khí\u003Cbr\u003E H\u003Csub\u003E2\u003C\u002Fsub\u003E (đktc) và 2,35 gam chất rắn không tan. Giá trị của m là\u003Cbr\u003E",[223,225,227,229],{"answer":224,"id":13}," 4,35",{"answer":226,"id":16}," 4,85",{"answer":228,"id":19}," 6,95",{"answer":230,"id":22}," 3,70\u003Cbr\u003E",18,{"question":233,"answers":234,"id":243,"right":22}," Một cốc nước chứa: a mol Ca\u003Csup\u003E2\u003C\u002Fsup\u003E\u003Csup\u003E+\u003C\u002Fsup\u003E, b mol Mg\u003Csup\u003E2\u003C\u002Fsup\u003E\u003Csup\u003E+\u003C\u002Fsup\u003E, c mol Cl\u003Csup\u003E-\u003C\u002Fsup\u003E và d mol HCO\u003Csub\u003E3\u003C\u002Fsub\u003E. Biểu thức liên hệ giữa a, b, c,",[235,237,239,241],{"answer":236,"id":13}," a + b = c + d",{"answer":238,"id":16}," 3a + 3b = c + d",{"answer":240,"id":19},"2a + 2b - c + d = 0",{"answer":242,"id":22}," 2a + 2b - c - d = 0\u003Cbr\u003E",19,{"question":245,"answers":246,"id":252,"right":16}," Hợp chất nào của crom có tính lưỡng tính?\u003Cbr\u003E",[247,248,249,250],{"answer":72,"id":13},{"answer":74,"id":16},{"answer":76,"id":19},{"answer":251,"id":22}," K\u003Csub\u003E2\u003C\u002Fsub\u003ECr\u003Csub\u003E2\u003C\u002Fsub\u003EO\u003Csub\u003E7\u003C\u002Fsub\u003E.\u003Cbr\u003E",20,{"question":254,"answers":255,"id":264,"right":16}," Khi nhiệt kế thủy ngân bị vỡ, ta cần sử dụng hóa chất nào sau đây để khử độc thủy ngân?\u003Cbr\u003E",[256,258,260,262],{"answer":257,"id":13}," muối ăn",{"answer":259,"id":16}," Lưu huỳnh",{"answer":261,"id":19}," Vôi sống",{"answer":263,"id":22}," Cacbon\u003Cbr\u003E",21,{"question":266,"answers":267,"id":276,"right":13}," Đổ từ từ dd chứa 0,25 mol HCl vào dd A gồm 0,2 mol NaHCO\u003Csub\u003E3\u003C\u002Fsub\u003E và 0,15 mol Na\u003Csub\u003E2\u003C\u002Fsub\u003ECO\u003Csub\u003E3\u003C\u002Fsub\u003E. Tìm VCO\u003Csub\u003E2\u003C\u002Fsub\u003E (đktc).\u003Cbr\u003E",[268,270,272,274],{"answer":269,"id":13}," 2,24 lít",{"answer":271,"id":16}," 3,36 lít",{"answer":273,"id":19}," 4,48 lít",{"answer":275,"id":22}," 5,6 lít\u003Cbr\u003E",22,{"question":278,"answers":279,"id":288,"right":16}," Cho sắt phản ứng với dung dịch HNO\u003Csub\u003E3\u003C\u002Fsub\u003E đặc, nóng thu được một chất khí màu nâu đỏ. Chất khí đó là\u003Cbr\u003E",[280,282,284,286],{"answer":281,"id":13}," N\u003Csub\u003E2\u003C\u002Fsub\u003EO.",{"answer":283,"id":16}," NO\u003Csub\u003E2\u003C\u002Fsub\u003E.",{"answer":285,"id":19}," NH\u003Csub\u003E3\u003C\u002Fsub\u003E.",{"answer":287,"id":22}," N\u003Csub\u003E2\u003C\u002Fsub\u003E.\u003Cbr\u003E",23,{"question":290,"answers":291,"id":300,"right":19}," Cho các dung dịch: KOH, NaCl, H\u003Csub\u003E2\u003C\u002Fsub\u003ESO\u003Csub\u003E4\u003C\u002Fsub\u003E loãng, HNO\u003Csub\u003E3\u003C\u002Fsub\u003E đặc nguội, CuSO\u003Csub\u003E4\u003C\u002Fsub\u003E, HCl. Có bao nhiêu dung dịch phản ứng được kim loại nhôm\u003Cbr\u003E",[292,294,296,298],{"answer":293,"id":13}," 2",{"answer":295,"id":16}," 3",{"answer":297,"id":19}," 4",{"answer":299,"id":22}," 5\u003Cbr\u003E",24,{"question":302,"answers":303,"id":312,"right":16}," Dãy gồm các chất đều có thể làm mất tính cứng tạm thời của nước là:\u003Cbr\u003E",[304,306,308,310],{"answer":305,"id":13}," HCl, NaOH, Na\u003Csub\u003E2\u003C\u002Fsub\u003ECO\u003Csub\u003E3\u003C\u002Fsub\u003E.",{"answer":307,"id":16}," NaOH, Na\u003Csub\u003E3\u003C\u002Fsub\u003EPO\u003Csub\u003E4\u003C\u002Fsub\u003E, Na\u003Csub\u003E2\u003C\u002Fsub\u003ECO\u003Csub\u003E3\u003C\u002Fsub\u003E.\u003Cbr\u003E",{"answer":309,"id":19}," KCl, Ca(OH)\u003Csub\u003E2\u003C\u002Fsub\u003E, Na\u003Csub\u003E2\u003C\u002Fsub\u003ECO\u003Csub\u003E3\u003C\u002Fsub\u003E.",{"answer":311,"id":22}," HCl, Ca(OH)\u003Csub\u003E2\u003C\u002Fsub\u003E, Na\u003Csub\u003E2\u003C\u0