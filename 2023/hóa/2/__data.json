\u002Fsub\u003E)\u003Csub\u003E3\u003C\u002Fsub\u003E thu được dd",[152,154,156,158],{"answer":153,"id":13}," 22,0.",{"answer":155,"id":16}," 10,0.",{"answer":157,"id":19}," 12,0.",{"answer":159,"id":22}," 7,6.\u003Cbr\u003E",12,{"question":162,"answers":163,"id":172,"right":19}," Cho từ từ dung dịch HCl vào dung dịch chứa hỗn hợp KOH và KAlO\u003Csub\u003E2\u003C\u002Fsub\u003E, sự biến thiên lượng kết tủa Al(OH)\u003Csub\u003E3\u003C\u002Fsub\u003E tạo thành trong thí nghiệm được biểu diễn trên đồ thị sau:\u003Cbr\u003E \u003Cimg src=\"\u002F2023\u002Fhoa214.png\"\u003E\u003Cbr\u003E Dựa vào đồ thị trên. Phát biểu nào đúng.\u003Cbr\u003E",[164,166,168,170],{"answer":165,"id":13}," Số mol KOH trong dung dịch là (4a+b) mol.\u003Cbr\u003E",{"answer":167,"id":16}," Sau khi kết tủa tan hết, trong dung dịch có 3 muối.\u003Cbr\u003E",{"answer":169,"id":19}," Số mol KAlO\u003Csub\u003E2\u003C\u002Fsub\u003E trong dung dịch là a mol.\u003Cbr\u003E",{"answer":171,"id":22}," Nếu thay dung dịch HCl bằng khí CO\u003Csub\u003E2\u003C\u002Fsub\u003E thì ta vẫn thu kết quả như đồ thị trên.\u003Cbr\u003E",13,{"question":174,"answers":175,"id":184,"right":19}," Cho luồng khí H\u003Csub\u003E2\u003C\u002Fsub\u003E dư qua hỗn hợp các oxit CuO, FeO, ZnO và Al\u003Csub\u003E2\u003C\u002Fsub\u003EO\u003Csub\u003E3\u003C\u002Fsub\u003E nung ở nhiệt độ cao. Sau phản ứng, hỗn hợp chất rắn còn lại là\u003Cbr\u003E",[176,178,180,182],{"answer":177,"id":13}," Cu, FeO, ZnO, Al\u003Csub\u003E2\u003C\u002Fsub\u003EO\u003Csub\u003E3\u003C\u002Fsub\u003E.",{"answer":179,"id":16}," Cu, Fe, ZnO, Al\u003Csub\u003E2\u003C\u002Fsub\u003EO\u003Csub\u003E3\u003C\u002Fsub\u003E.\u003Cbr\u003E",{"answer":181,"id":19}," Cu, Fe, Zn, Al\u003Csub\u003E2\u003C\u002Fsub\u003EO\u003Csub\u003E3\u003C\u002Fsub\u003E.",{"answer":183,"id":22}," Cu, Fe, Zn, Al.\u003Cbr\u003E",14,{"question":186,"answers":187,"id":195,"right":16}," Hêmatit là một trong những quặng quan trọng của sắt. Thành phần chính của quặng là.\u003