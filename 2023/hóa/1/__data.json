rong dung dịch FeCl\u003Csub\u003E2\u003C\u002Fsub\u003E dư.\u003Cbr\u003E Số phát biểu đúng là\u003Cbr\u003E",[446,448,450,452],{"answer":447,"id":13}," 3.",{"answer":449,"id":16}," 2.",{"answer":451,"id":19}," 5.",{"answer":453,"id":22}," 4.\u003Cbr\u003E",37,{"question":456,"answers":457,"id":466,"right":13}," Hòa tan hoàn hoàn m gam hỗn hợp K, K\u003Csub\u003E2\u003C\u002Fsub\u003EO, Ba, BaO vào nước thì thu được dung dịch Y và 0,01 mol H\u003Csub\u003E2\u003C\u002Fsub\u003E.\u003Cbr\u003E Làm các thí nghiệm khi dẫn khí CO2 vào dung dịch Y cho ta bảng giá trị sau. Hãy tìm m?\u003Cbr\u003E \u003Ctable\u003E\u003Ctr\u003E\u003Ctd\u003EMol CO\u003Csub\u003E2\u003C\u002Fsub\u003E\u003C\u002Ftd\u003E\u003Ctd\u003E0.02\u003C\u002Ftd\u003E\u003Ctd\u003E0.04\u003C\u002Ftd\u003E\u003Ctd\u003E0.09\u003C\u002Ftd\u003E\u003C\u002Ftr\u003E\u003Ctr\u003E\u003Ctd\u003EKhối lượng kết tủa\u003C\u002Ftd\u003E\u003Ctd\u003Ea\u003C\u002Ftd\u003E\u003Ctd\u003Ea+1.97\u003C\u002Ftd\u003E\u003Ctd\u003E0.5a\u003C\u002Ftd\u003E\u003C\u002Ftr\u003E\u003C\u002Ftable\u003E\u003Cbr\u003E",[458,460,462,464],{"answer":459,"id":13}," 6.31 gam\u003Cbr\u003E",{"answer":461,"id":16}," 3.155 gam\u003Cbr\u003E",{"answer":463,"id":19}," 12.62 gam\u003Cbr\u003E",{"answer":465,"id":22}," 9.465 gam\u003Cbr\u003E",38,{"question":468,"answers":469,"id":478,"right":13}," Hòa tan hoàn toàn 17,6 gam hỗn hợp X chứa Fe và Mg bằng dung dịch HCl (dư 25% so với phản ứng) thu được dung dịch Y và 8,96 lít (đktc). Cho AgNO\u003Csub\u003E3\u003C\u002Fsub\u003E dư vào Y thấy có khí NO (NO là sản phẩm khử duy nhất của gốc NO3\u003Csup\u003E−\u003C\u002Fsup\u003E ) và m gam kết tủa xuất hiện; còn lại chỉ là dung dịch chứa các muối nitrat. Giá trị của m?\u003Cbr\u003E",[470,472,474,476],{"answer":471,"id":13}," 154.3 gam\u003Cbr\u003E",{"answer":473,"id":16}," 77.15 gam\u003Cbr\u003E",{"answer":475,"id":19}," 308.6 gam\u003Cbr\u003E",{"answer":477,"id":22}," 231.45 gam\u003Cbr\u003E",39,"https:\u002F\u002Fazota.vn\u002Fd