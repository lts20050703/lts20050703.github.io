{
	"incremental": true,
	"useTabs": true,
	"typescript": { "semiColons": "asi", "preferHanging": true },
	"json": { "preferSingleLine": true },
	"markdown": {},
	"prettier": { "printWidth": 120, "useTab": true },
	"includes": ["*.{ts,js,json,md,html,css}"],
	"excludes": ["dist", "node_modules"],
	"plugins": [
		"https://plugins.dprint.dev/typescript-0.66.0.wasm",
		"https://plugins.dprint.dev/json-0.15.0.wasm",
		"https://plugins.dprint.dev/markdown-0.13.0.wasm",
		"https://plugins.dprint.dev/prettier-0.6.1.exe-plugin@2d54d5f8dbdeb087762fadc4840c688327f5deab447c94b32ca3850106db9224"
	]
}
