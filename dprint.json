{
	"useTabs": true,
	"incremental": true,
	"typescript": {
		"bracePosition": "sameLine",
		"nextControlFlowPosition": "sameLine",
		"semiColons": "asi",
		"singleBodyPosition": "sameLine",
		"trailingCommas": "never",
		"useBraces": "preferNone"
	},
	"prettier": {
		"printWidth": 120,
		"useTab": true
	},
	"includes": [
		"**/*.{ts,json,jsonc,md,html,css}"
	],
	"excludes": [
		"**/node_modules",
		"**/package*.json"
	],
	"plugins": [
		"https://plugins.dprint.dev/typescript-0.64.0.wasm",
		"https://plugins.dprint.dev/json-0.14.1.wasm",
		"https://plugins.dprint.dev/markdown-0.12.2.wasm",
		"https://plugins.dprint.dev/prettier-0.5.1.exe-plugin@3b0f36f27222453e24a25786969e687a3bcef29f3df00c9d7246cba9f85956d3"
	]
}
