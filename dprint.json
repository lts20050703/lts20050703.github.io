{
	"incremental": true,
	"useTabs": true,
	"typescript": { "semiColons": "asi", "preferHanging": true },
	"json": { "preferSingleLine": true },
	"markdown": {},
	"prettier": { "printWidth": 120, "useTab": true },
	"includes": ["*.{ts,js,json,md,html,css}"],
	"excludes": ["dist", "node_modules"],
	"plugins": [
		"https://plugins.dprint.dev/typescript-0.68.2.wasm",
		"https://plugins.dprint.dev/json-0.15.2.wasm",
		"https://plugins.dprint.dev/markdown-0.13.2.wasm",
		"https://plugins.dprint.dev/prettier-0.7.2.json@04c4c97ec64f171a18e24336fc5d2cdd6401a762836a1631b832abbe0dd6ec82"
	]
}
